{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Resortes Puerto Montt",
  "version": "../package.json",
  "identifier": "cl.resortespuertomontt.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Resortes Puerto Montt",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Resortes Puerto Montt",
    "shortDescription": "Gestión de taller y resortes — ventas, órdenes, inventario e informes.",
    "longDescription": "Aplicación de escritorio para administrar un taller de resortes: clientes, órdenes de trabajo, cotizaciones, inventario, créditos, anticipos, gastos, mecánicos, informes y respaldos.",
    "copyright": "Copyright © Resortes Puerto Montt",
    "category": "Business",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Spanish", "English"],
        "displayLanguageSelector": true,
        "installMode": "currentUser"
      }
    }
  }
}
